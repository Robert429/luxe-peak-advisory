---
import '../styles/global.css';
import type { SiteContent } from '../data/content';

interface Props { content: SiteContent }
const { content } = Astro.props;
---
<!doctype html>
<html lang={content.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
    <link rel="icon" href="/favicon_io/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon_io/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon_io/site.webmanifest" />
    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={`https://luxepeakadvisory.com${content.path}`} />
    <link rel="alternate" hreflang={content.lang} href={content.path} />
    <link rel="alternate" hreflang={content.lang === 'en' ? 'es' : 'en'} href={content.altPath} />
    <link rel="alternate" hreflang="x-default" href="/" />
  </head>
  <body class="bg-ivory text-charcoal font-body antialiased">
    <slot />
  </body>
</html>
