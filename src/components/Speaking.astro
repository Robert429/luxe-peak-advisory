---
import type { SiteContent } from '../data/content';
import Icon from './Icon.astro';
interface Props { content: SiteContent }
const { content } = Astro.props;
const { speaking } = content;
const icons = ['mic', 'people', 'crown'];
---
<section id="speaking" class="bg-navy text-ivory py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-5">
      <p class="text-gold text-xs tracking-[0.2em] uppercase mb-3">{speaking.eyebrow}</p>
      <h2 class="font-display text-3xl lg:text-4xl mb-4">{speaking.title}</h2>
      <p class="text-ivory/70 leading-relaxed mb-6">{speaking.body}</p>
      <p class="text-gold/80 text-sm italic mb-6">{speaking.podcastNote}</p>
      <a href="#contact" class="inline-block border border-gold text-gold px-6 py-3 text-xs tracking-widest uppercase hover:bg-gold hover:text-navy transition-colors">{speaking.ctaLabel}</a>
    </div>
    <div class="lg:col-span-7 grid sm:grid-cols-3 gap-6">
      {speaking.items.map((item, i) => (
        <div class="border border-gold/25 p-6 text-center">
          <div class="text-gold mb-4 flex justify-center"><Icon name={icons[i % icons.length]} /></div>
          <p class="font-display text-lg mb-2">{item.label}</p>
          <p class="text-ivory/60 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
