---
import { Image } from 'astro:assets';
import type { SiteContent } from '../data/content';
import bestWestern from '../imgs/comp_logos/best-western.png';
import courtyard from '../imgs/comp_logos/courtyard.png';
import hamptonInn from '../imgs/comp_logos/hampton-inn.png';
import hilton from '../imgs/comp_logos/hilton.png';
import holidayInnExpress from '../imgs/comp_logos/holiday-inn-express.png';
import holidayInnSuites from '../imgs/comp_logos/holiday-inn-suites.png';
import marriott from '../imgs/comp_logos/marriott.png';
import hyattRegency from '../imgs/comp_logos/hyatt-regency.png';
import residenceInn from '../imgs/comp_logos/residence-inn.png';
import ritzCarlton from '../imgs/comp_logos/ritz-carlton.png';
import fairfieldByMarriott from '../imgs/comp_logos/fairfield-by-marriott.png';
interface Props { content: SiteContent }
const { content } = Astro.props;
const { results } = content;
const brandLogos = [bestWestern, courtyard, hamptonInn, hilton, holidayInnExpress, holidayInnSuites, marriott, hyattRegency, residenceInn, ritzCarlton, fairfieldByMarriott];
---
<section id="results" class="bg-ivory py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-2xl mb-14">
      <p class="text-magenta text-xs tracking-[0.2em] uppercase mb-3">{results.eyebrow}</p>
      <h2 class="font-display text-3xl lg:text-4xl text-navy mb-4">{results.title}</h2>
      <p class="text-warmgray leading-relaxed">{results.intro}</p>
    </div>
    <div class="grid lg:grid-cols-2 gap-6">
      {results.cases.map((c) => (
        <div class="bg-white border border-gold/25 p-8 flex flex-col">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-display text-navy text-xl">{c.property}</h3>
              <p class="text-warmgray text-xs mt-1">{c.role} · {c.period}</p>
            </div>
            <span class="flex-shrink-0 text-xs tracking-wide uppercase bg-navy text-gold px-3 py-1.5 whitespace-nowrap">{c.metric}</span>
          </div>
          <p class="text-charcoal/80 text-sm leading-relaxed">{c.summary}</p>
        </div>
      ))}
    </div>
    <p class="text-warmgray/70 text-xs mt-8 italic">{results.recognition}</p>
  </div>
  <div class="mt-16 border-t border-gold/20 pt-10">
    <p class="text-center text-warmgray text-xs tracking-[0.2em] uppercase mb-8">{results.brandsLabel}</p>
    <div class="marquee-mask overflow-hidden">
      <div class="marquee-track flex items-center gap-16 w-max">
        {[...brandLogos, ...brandLogos].map((logo) => (
          <Image src={logo} alt="" class="h-10 w-auto object-contain grayscale opacity-60 flex-shrink-0" />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-mask {
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .marquee-track {
    animation: marquee 45s linear infinite;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
