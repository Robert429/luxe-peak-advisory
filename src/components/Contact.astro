---
import type { SiteContent } from '../data/content';
interface Props { content: SiteContent }
const { content } = Astro.props;
const { contact, services } = content;
---
<section id="contact" class="bg-navy text-ivory py-20 lg:py-28 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
    <div>
      <h2 class="font-display text-3xl lg:text-5xl mb-6 leading-tight">{contact.title}</h2>
      <p class="text-ivory/70 max-w-md mb-10 leading-relaxed">{contact.body}</p>
      <div class="flex flex-col gap-6 mb-10 text-sm">
        <div>
          <span class="text-gold/80 block text-xs tracking-widest uppercase mb-1">{contact.emailLabel}</span>
          <a href="mailto:vickyperez@luxepeakadvisory.com" class="hover:text-gold transition-colors">vickyperez@luxepeakadvisory.com</a>
        </div>
        <div>
          <span class="text-gold/80 block text-xs tracking-widest uppercase mb-1">{contact.whatsappLabel}</span>
          <a href="tel:+15128939379" class="hover:text-gold transition-colors">+1 512-893-9379</a>
        </div>
      </div>
    </div>
    <form
      action="mailto:vickyperez@luxepeakadvisory.com"
      method="POST"
      enctype="text/plain"
      class="bg-ivory text-charcoal rounded-sm shadow-2xl p-6 sm:p-8"
    >
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="firstName" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formFirstName}</label>
          <input id="firstName" name="firstName" type="text" required class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold" />
        </div>
        <div>
          <label for="lastName" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formLastName}</label>
          <input id="lastName" name="lastName" type="text" required class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold" />
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formEmail}</label>
          <input id="email" name="email" type="email" required class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold" />
        </div>
        <div>
          <label for="phone" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formPhone}</label>
          <input id="phone" name="phone" type="tel" required class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold" />
        </div>
      </div>
      <div class="mb-5">
        <label for="service" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formServiceLabel}</label>
        <select id="service" name="service" required class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold">
          <option value="" selected disabled>{contact.formServicePlaceholder}</option>
          {services.map((s) => <option value={s.title}>{s.title}</option>)}
          <option value={contact.formServiceOther}>{contact.formServiceOther}</option>
        </select>
      </div>
      <div class="mb-6">
        <label for="message" class="block text-xs tracking-widest uppercase text-warmgray mb-2">{contact.formMessageLabel}</label>
        <textarea id="message" name="message" rows="5" required placeholder={contact.formMessagePlaceholder} class="w-full border border-gold/30 rounded-sm px-4 py-3 text-sm bg-white focus:outline-none focus:border-gold resize-none"></textarea>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="inline-flex items-center gap-3 bg-magenta text-white px-8 py-4 text-xs tracking-widest uppercase hover:bg-magenta/90 transition-colors">
          {contact.formSend}
        </button>
      </div>
    </form>
  </div>
</section>
